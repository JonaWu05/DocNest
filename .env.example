# 複製本檔為 .env 後填入實際值。
# 文件根目錄：所有可瀏覽/編輯的 .md、.txt 檔案都放在這個目錄底下
DOC_ROOT=./docs

# 服務埠號
PORT=8080

# 網頁標題（瀏覽器分頁與登入頁大標）；留空則使用預設「Markdown 編輯器」
APP_TITLE=

# 登入頁自訂背景圖；留空則用內建暗色漸層。可填 /static/... 路徑（將圖片放到 web/ 底下）或外部圖片 URL
#   例：LOGIN_BG=/static/login-bg.jpg  或  LOGIN_BG=https://example.com/bg.jpg
LOGIN_BG=

# 允許的跨來源網域（CORS 與 WebSocket 共用），多組以逗號分隔，例如：
#   ALLOWED_ORIGINS=https://md.example.com,https://www.example.com
# 留空代表開發模式：允許所有來源（正式環境請務必設定）。
ALLOWED_ORIGINS=

# 信任的反向代理來源（逗號分隔，支援 IP 或 CIDR）。架在 Nginx/反向代理後方時設定，
# gin 才會讀 X-Forwarded-For 還原真實客戶端 IP（登入限流與存取紀錄才正確）。
# 代理與本服務同機填 127.0.0.1；不同機填代理那台的 IP，例：TRUSTED_PROXIES=172.24.15.23
# 留空（預設）代表不信任任何代理。
TRUSTED_PROXIES=

# 登入後自動開啟的首頁文件（相對 DOC_ROOT，選填）。留空則登入後顯示空白工作區。
DEFAULT_DOC=welcome.md

# 存檔時是否 fsync 強制刷盤。預設 false（多數檔案型應用的做法，較省磁碟 I/O）。
# 關閉不影響原子性（仍靠 temp+rename，讀者不會讀到半檔），僅放棄「斷電當下那一存」的耐久保證。
# 對耐久要求高、或部署在易斷電環境時，可設為 true。
FSYNC_ON_SAVE=false

# ===== Local accounts =====
# 格式：username:bcryptHash，多組以逗號分隔。
# 密碼一律以 bcrypt hash 儲存（不存明文）。產生 hash：go run ./cmd/hashpw '你的密碼'
# 注意：bcrypt hash 含 $，整個值「必須」用單引號包住，否則 godotenv 會展開 $xx 毀掉 hash。
USERS='alice:請填入bcryptHash,bob:請填入bcryptHash'

# ===== JWT =====
# JWT_SECRET 請用隨機字串，產生指令：openssl rand -base64 32
JWT_SECRET='請填入隨機密鑰'
JWT_EXPIRE_HOURS=24

# ===== Discord OAuth（選填，未設定則停用 Discord 登入）=====
# Redirect URI 需與 Discord 後台設定一致：http://localhost:8080/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback
# 允許登入的 Discord User ID，多組以逗號分隔
DISCORD_ALLOWED_IDS=
